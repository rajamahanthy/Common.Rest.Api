{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SurveyDb": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=SurveyDataDb;Integrated Security=True;Persist Security Info=False;Pooling=False;Multiple Active Result Sets=False;Encrypt=False;Trust Server Certificate=True;Application Name=\"SQL Server Management Studio\";Command Timeout=0"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID",
    "Audience": "api://YOUR_CLIENT_ID"
  },
  "ApplicationInsights": {
    "ConnectionString": "YOUR_APPINSIGHTS_CONNECTION_STRING"
  },
  "Resilience": {
    "MaxRetryAttempts": 3,
    "DelaySeconds": 1.0,
    "BackoffType": "Exponential",
    "UseJitter": true
  },
  "KeyVault": {
    "VaultUri": "https://YOUR_KEYVAULT.vault.azure.net/"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}

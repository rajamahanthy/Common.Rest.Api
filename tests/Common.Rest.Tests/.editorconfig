##########################
# ENABLED RULES: WARNING (First Wave - High Value)
##########################

# CA1707: Identifiers should not contain underscores
# Enforces naming conventions for public members (PascalCase, no underscores)
dotnet_diagnostic.CA1707.severity = warning

# CA1711: Identifiers should not have incorrect suffix
# Catches FlagAttribute enums named with 'Flag', 'Flags' suffixes
dotnet_diagnostic.CA1711.severity = warning

# CA1801: Review unused parameters
# Detects unused method parameters to help clean up signatures
dotnet_diagnostic.CA1801.severity = warning

# CA1802: Use literals where appropriate
# Promotes static readonly to const where possible
dotnet_diagnostic.CA1802.severity = warning

# CA1806: Do not ignore method results
# Warns when return values are ignored (often bugs)
dotnet_diagnostic.CA1806.severity = warning

# CA1822: Mark members as static
# Identifies instance methods that don't use 'this'
dotnet_diagnostic.CA1822.severity = warning

# CA1827: Do not use Count/LongCount when Any can be used
# Performance: Any() is faster than Count() > 0
dotnet_diagnostic.CA1827.severity = warning

# CA1849: Call async methods when in an async context
# Async best practice: don't call sync methods from async code
dotnet_diagnostic.CA1849.severity = warning

# CA2100: Review SQL queries for security vulnerabilities
# SECURITY: Detects potential SQL injection risks
dotnet_diagnostic.CA2100.severity = warning

# CS1998: Async method lacks await operators
# Flags async methods that don't actually await anything
dotnet_diagnostic.CS1998.severity = warning

# IDE0001: Simplify type names
# Style: Remove unnecessary namespaces in type references
dotnet_diagnostic.IDE0001.severity = warning

# IDE0161: Use file-scoped namespace
# Style: Prefer file-scoped namespaces (.NET 6+)
dotnet_diagnostic.IDE0161.severity = warning

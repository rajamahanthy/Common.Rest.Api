# EditorConfig is awesome: https://EditorConfig.org
root = true

########################################
# GLOBAL SETTINGS
########################################
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

##########################
# Default: Silent (No Warnings)
##########################
[*.cs]
# Disable all by default - only exceptions below are enabled
dotnet_diagnostic.CA1000.severity = silent
dotnet_diagnostic.CA1001.severity = silent
dotnet_diagnostic.CA1009.severity = silent
